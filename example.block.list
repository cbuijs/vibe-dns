##### BLOCK QUERIES #####

# Block domain and just that domain (no subdomains).
domain.com

# Block domain and all sub-domains.
.domain.com

# Block only sub-domains but not the domain.
*.domain.com

# Block domain matching a regex.
/^.*badguys.*$/




##### BLOCK ANSWERS #####
#
# IP-Addresses are filtered when matching a IP or CIDR rule for A and AAAA record types.
#
# Domain-names are blocked for CNAME, MX, NS, PTR and SRV records, matching the correct field.
#

# Block domain and just that domain (no subdomains).
@domain.com

# Block domain and all sub-domains.
@.domain.com

# Block only sub-domains but not the domain.
@*.domain.com

# Filter out an IP-Address from an answer set.
1.2.3.4

# Filter out ip-address from an answer set in a network/subnet (CIDR).
192.168.10.0/24

# Block domain matching a regex.
@/^.*badguys.*$/

